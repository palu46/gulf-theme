{
    "$schema": "vscode://schemas/color-theme",
    "name": "Gulf Dark Editor",
    "include": "./gulf-dark-color-theme.json",
    "type": "dark",
    "tokenColors": [
      {
        "name": "Comment",
        "scope": [
          "comment",
          "punctuation.definition.comment",
          "string.comment",
          "comment.block",
          "comment.line"
        ],
        "settings": {
          "foreground": "#6f7fb0",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Keyword",
        "scope": [
          "keyword",
          "keyword.control",
          "keyword.other",
          "keyword.operator.expression",
          "keyword.operator.new",
          "keyword.operator.logical",
          "keyword.operator.wordlike",
          "storage",
          "storage.type",
          "storage.modifier"
        ],
        "settings": {
          "foreground": "#ff7403"
        }
      },
      {
        "name": "Operator",
        "scope": [
          "keyword.operator",
          "punctuation.accessor",
          "keyword.operator.assignment",
          "keyword.operator.arithmetic",
          "keyword.operator.comparison"
        ],
        "settings": {
          "foreground": "#a7b4d8"
        }
      },
      {
        "name": "Storage type def",
        "scope": [
          "storage.type.function",
          "storage.type.class",
          "keyword.declaration"
        ],
        "settings": {
          "foreground": "#ff7403"
        }
      },
      {
        "name": "String",
        "scope": [
          "string",
          "string.quoted",
          "string.template",
          "string.unquoted",
          "meta.string"
        ],
        "settings": {
          "foreground": "#3edd9b"
        }
      },
      {
        "name": "String punctuation",
        "scope": [
          "punctuation.definition.string"
        ],
        "settings": {
          "foreground": "#3edd9b"
        }
      },
      {
        "name": "Template expression punctuation",
        "scope": [
          "punctuation.definition.template-expression",
          "punctuation.section.embedded",
          "meta.template.expression"
        ],
        "settings": {
          "foreground": "#a7b4d8"
        }
      },
      {
        "name": "Regex",
        "scope": [
          "string.regexp",
          "constant.other.character-class.regexp",
          "keyword.control.anchor.regexp"
        ],
        "settings": {
          "foreground": "#b9a4f2"
        }
      },
      {
        "name": "Escape",
        "scope": [
          "constant.character.escape",
          "constant.other.placeholder",
          "constant.character.format.placeholder"
        ],
        "settings": {
          "foreground": "#ffc24b"
        }
      },
      {
        "name": "Number",
        "scope": [
          "constant.numeric",
          "constant.numeric.integer",
          "constant.numeric.float",
          "constant.numeric.hex"
        ],
        "settings": {
          "foreground": "#ff5d73"
        }
      },
      {
        "name": "Boolean / language constant",
        "scope": [
          "constant.language",
          "constant.language.boolean",
          "constant.language.null",
          "constant.language.undefined",
          "constant.language.nan",
          "constant.language.infinity"
        ],
        "settings": {
          "foreground": "#ff5d73"
        }
      },
      {
        "name": "Constant",
        "scope": [
          "constant",
          "constant.other",
          "variable.other.constant",
          "variable.other.enummember",
          "entity.name.constant",
          "support.constant"
        ],
        "settings": {
          "foreground": "#ff5d73"
        }
      },
      {
        "name": "Function",
        "scope": [
          "entity.name.function",
          "support.function",
          "meta.function-call.generic",
          "meta.function-call",
          "variable.function"
        ],
        "settings": {
          "foreground": "#ffc24b"
        }
      },
      {
        "name": "Function builtin",
        "scope": [
          "support.function.builtin",
          "support.function.magic"
        ],
        "settings": {
          "foreground": "#ffc24b"
        }
      },
      {
        "name": "Type / class",
        "scope": [
          "entity.name.type",
          "entity.name.class",
          "entity.other.inherited-class",
          "support.type",
          "support.class",
          "entity.name.type.class",
          "entity.name.type.interface",
          "entity.name.type.enum",
          "entity.name.type.struct",
          "meta.type.annotation",
          "support.type.primitive"
        ],
        "settings": {
          "foreground": "#56d4dd"
        }
      },
      {
        "name": "Namespace",
        "scope": [
          "entity.name.namespace",
          "entity.name.module",
          "entity.name.scope-resolution"
        ],
        "settings": {
          "foreground": "#56d4dd"
        }
      },
      {
        "name": "Type parameter",
        "scope": [
          "entity.name.type.parameter",
          "meta.type.parameters"
        ],
        "settings": {
          "foreground": "#56d4dd",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Decorator",
        "scope": [
          "meta.decorator",
          "punctuation.decorator",
          "entity.name.function.decorator",
          "tag.decorator",
          "meta.annotation",
          "storage.type.annotation",
          "entity.name.function.preprocessor",
          "meta.preprocessor"
        ],
        "settings": {
          "foreground": "#b9a4f2"
        }
      },
      {
        "name": "Macro",
        "scope": [
          "entity.name.function.macro",
          "meta.macro",
          "support.function.macro"
        ],
        "settings": {
          "foreground": "#b9a4f2"
        }
      },
      {
        "name": "Parameter",
        "scope": [
          "variable.parameter",
          "variable.parameter.function",
          "meta.function.parameters"
        ],
        "settings": {
          "foreground": "#93dafe"
        }
      },
      {
        "name": "Property / object key",
        "scope": [
          "variable.other.property",
          "variable.other.object.property",
          "meta.object-literal.key",
          "support.type.property-name",
          "meta.object.member",
          "variable.object.property",
          "entity.name.tag.yaml",
          "support.type.property-name.json",
          "support.type.property-name.toml"
        ],
        "settings": {
          "foreground": "#93dafe"
        }
      },
      {
        "name": "Language variable (this/self/super)",
        "scope": [
          "variable.language",
          "variable.language.this",
          "variable.language.super"
        ],
        "settings": {
          "foreground": "#ff5d73"
        }
      },
      {
        "name": "Variable",
        "scope": [
          "variable",
          "variable.other",
          "variable.other.readwrite",
          "meta.definition.variable",
          "meta.variable"
        ],
        "settings": {
          "foreground": "#c9d1d9"
        }
      },
      {
        "name": "Built-in / support variable",
        "scope": [
          "support.variable",
          "support.other.variable",
          "variable.other.global"
        ],
        "settings": {
          "foreground": "#93dafe"
        }
      },
      {
        "name": "Tag",
        "scope": [
          "entity.name.tag",
          "punctuation.definition.tag",
          "meta.tag"
        ],
        "settings": {
          "foreground": "#ff5d73"
        }
      },
      {
        "name": "Tag component (JSX/Vue)",
        "scope": [
          "support.class.component",
          "entity.name.tag.namespace",
          "meta.tag.custom"
        ],
        "settings": {
          "foreground": "#56d4dd"
        }
      },
      {
        "name": "Attribute name",
        "scope": [
          "entity.other.attribute-name",
          "meta.attribute"
        ],
        "settings": {
          "foreground": "#ffc24b"
        }
      },
      {
        "name": "Punctuation",
        "scope": [
          "punctuation",
          "punctuation.definition",
          "punctuation.separator",
          "punctuation.terminator",
          "punctuation.section",
          "meta.brace.round",
          "meta.brace.square",
          "meta.brace.curly",
          "punctuation.definition.parameters",
          "punctuation.definition.array"
        ],
        "settings": {
          "foreground": "#8295c6"
        }
      },
      {
        "name": "Label",
        "scope": [
          "entity.name.label",
          "entity.name.goto-label"
        ],
        "settings": {
          "foreground": "#93dafe"
        }
      },
      {
        "name": "CSS tag selector",
        "scope": [
          "entity.name.tag.css",
          "entity.name.tag.scss"
        ],
        "settings": {
          "foreground": "#ff5d73"
        }
      },
      {
        "name": "CSS class/id selector",
        "scope": [
          "entity.other.attribute-name.class.css",
          "entity.other.attribute-name.id.css",
          "entity.other.attribute-name.pseudo-class.css",
          "entity.other.attribute-name.pseudo-element.css"
        ],
        "settings": {
          "foreground": "#ffc24b"
        }
      },
      {
        "name": "CSS property name",
        "scope": [
          "support.type.property-name.css",
          "support.type.property-name.scss",
          "meta.property-name.css"
        ],
        "settings": {
          "foreground": "#93dafe"
        }
      },
      {
        "name": "CSS property value",
        "scope": [
          "support.constant.property-value.css",
          "meta.property-value.css",
          "support.constant.font-name.css"
        ],
        "settings": {
          "foreground": "#3edd9b"
        }
      },
      {
        "name": "CSS unit",
        "scope": [
          "keyword.other.unit",
          "constant.numeric.css"
        ],
        "settings": {
          "foreground": "#ff5d73"
        }
      },
      {
        "name": "CSS color",
        "scope": [
          "constant.other.color",
          "constant.other.color.rgb-value"
        ],
        "settings": {
          "foreground": "#56d4dd"
        }
      },
      {
        "name": "Heading",
        "scope": [
          "markup.heading",
          "entity.name.section",
          "punctuation.definition.heading"
        ],
        "settings": {
          "foreground": "#93dafe",
          "fontStyle": "bold"
        }
      },
      {
        "name": "Bold",
        "scope": [
          "markup.bold",
          "punctuation.definition.bold"
        ],
        "settings": {
          "foreground": "#ff7403",
          "fontStyle": "bold"
        }
      },
      {
        "name": "Italic",
        "scope": [
          "markup.italic",
          "punctuation.definition.italic"
        ],
        "settings": {
          "foreground": "#3edd9b",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Inline code",
        "scope": [
          "markup.inline.raw",
          "markup.raw",
          "punctuation.definition.raw"
        ],
        "settings": {
          "foreground": "#3edd9b"
        }
      },
      {
        "name": "Link",
        "scope": [
          "markup.underline.link",
          "string.other.link",
          "constant.other.reference.link"
        ],
        "settings": {
          "foreground": "#56d4dd",
          "fontStyle": "underline"
        }
      },
      {
        "name": "Quote",
        "scope": [
          "markup.quote",
          "punctuation.definition.quote"
        ],
        "settings": {
          "foreground": "#8295c6",
          "fontStyle": "italic"
        }
      },
      {
        "name": "List bullet",
        "scope": [
          "markup.list",
          "punctuation.definition.list.begin",
          "beginning.punctuation.definition.list"
        ],
        "settings": {
          "foreground": "#ff7403"
        }
      },
      {
        "name": "Diff inserted",
        "scope": [
          "markup.inserted",
          "markup.inserted.diff",
          "meta.diff.header.to-file"
        ],
        "settings": {
          "foreground": "#3edd9b"
        }
      },
      {
        "name": "Diff deleted",
        "scope": [
          "markup.deleted",
          "markup.deleted.diff",
          "meta.diff.header.from-file"
        ],
        "settings": {
          "foreground": "#ff5d73"
        }
      },
      {
        "name": "Diff changed",
        "scope": [
          "markup.changed",
          "markup.changed.diff"
        ],
        "settings": {
          "foreground": "#ffc24b"
        }
      },
      {
        "name": "Diff header / range",
        "scope": [
          "meta.diff.header",
          "meta.diff.range",
          "punctuation.definition.range.diff"
        ],
        "settings": {
          "foreground": "#b9a4f2"
        }
      },
      {
        "name": "Invalid",
        "scope": [
          "invalid",
          "invalid.illegal"
        ],
        "settings": {
          "foreground": "#ff5d73"
        }
      },
      {
        "name": "Deprecated",
        "scope": [
          "invalid.deprecated"
        ],
        "settings": {
          "foreground": "#6f7fb0",
          "fontStyle": "strikethrough"
        }
      },
      {
        "name": "Token info",
        "scope": [
          "token.info-token"
        ],
        "settings": {
          "foreground": "#56d4dd"
        }
      },
      {
        "name": "Token warn",
        "scope": [
          "token.warn-token"
        ],
        "settings": {
          "foreground": "#ffc24b"
        }
      },
      {
        "name": "Token error",
        "scope": [
          "token.error-token"
        ],
        "settings": {
          "foreground": "#ff5d73"
        }
      },
      {
        "name": "Token debug",
        "scope": [
          "token.debug-token"
        ],
        "settings": {
          "foreground": "#b9a4f2"
        }
      },
      {
        "name": "C/C++ preprocessor directive",
        "scope": [
          "keyword.control.directive",
          "keyword.control.directive.include",
          "keyword.control.directive.define",
          "keyword.control.directive.conditional",
          "keyword.control.directive.pragma",
          "keyword.control.directive.undef",
          "keyword.control.import.c",
          "keyword.control.import.cpp",
          "punctuation.definition.directive",
          "meta.preprocessor"
        ],
        "settings": {
          "foreground": "#b9a4f2"
        }
      },
      {
        "name": "C/C++ macro name",
        "scope": [
          "entity.name.function.preprocessor",
          "entity.name.function.preprocessor.c",
          "entity.name.function.preprocessor.cpp",
          "variable.other.macro",
          "meta.preprocessor.macro entity.name.function"
        ],
        "settings": {
          "foreground": "#b9a4f2"
        }
      },
      {
        "name": "C/C++ include path",
        "scope": [
          "string.quoted.other.lt-gt.include",
          "string.quoted.other.lt-gt.include.c",
          "string.quoted.other.lt-gt.include.cpp",
          "string.quoted.double.include"
        ],
        "settings": {
          "foreground": "#3edd9b"
        }
      },
      {
        "name": "C/C++ built-in type",
        "scope": [
          "storage.type.built-in.c",
          "storage.type.built-in.cpp",
          "storage.type.built-in.primitive.c",
          "storage.type.built-in.primitive.cpp",
          "storage.type.primitive.c",
          "storage.type.primitive.cpp",
          "support.type.built-in.c",
          "support.type.built-in.cpp",
          "support.type.posix-reserved.c",
          "support.type.posix-reserved.cpp",
          "support.type.sys-types.c"
        ],
        "settings": {
          "foreground": "#56d4dd"
        }
      },
      {
        "name": "C/C++ namespace / scope resolution",
        "scope": [
          "entity.name.namespace",
          "entity.name.scope-resolution",
          "entity.name.scope-resolution.cpp",
          "entity.name.scope-resolution.parameter",
          "meta.body.scope-resolution"
        ],
        "settings": {
          "foreground": "#56d4dd"
        }
      },
      {
        "name": "C/C++ struct/class member",
        "scope": [
          "variable.other.member",
          "variable.other.property.cpp",
          "variable.other.object.property.cpp",
          "meta.member.access"
        ],
        "settings": {
          "foreground": "#93dafe"
        }
      },
      {
        "name": "C/C++ function call",
        "scope": [
          "entity.name.function.call",
          "entity.name.function.call.cpp",
          "meta.function-call.cpp",
          "entity.name.function.member",
          "entity.name.function.definition.special.member.destructor"
        ],
        "settings": {
          "foreground": "#ffc24b"
        }
      },
      {
        "name": "C/C++ attribute",
        "scope": [
          "support.other.attribute",
          "support.other.attribute.cpp",
          "meta.attribute.cpp",
          "meta.attribute-specifier"
        ],
        "settings": {
          "foreground": "#b9a4f2"
        }
      },
      {
        "name": "C/C++ this",
        "scope": [
          "variable.language.this.cpp",
          "variable.language.this.c"
        ],
        "settings": {
          "foreground": "#ff5d73"
        }
      },
      {
        "name": "C++ template keyword",
        "scope": [
          "storage.type.template",
          "storage.type.template.cpp",
          "keyword.other.template",
          "keyword.other.typename"
        ],
        "settings": {
          "foreground": "#ff7403"
        }
      },
      {
        "name": "Python self / cls",
        "scope": [
          "variable.language.special.self.python",
          "variable.language.special.cls.python",
          "variable.parameter.function.language.special.self.python",
          "variable.parameter.function.language.special.cls.python"
        ],
        "settings": {
          "foreground": "#ff5d73"
        }
      },
      {
        "name": "Python builtin function",
        "scope": [
          "support.function.builtin.python"
        ],
        "settings": {
          "foreground": "#ffc24b"
        }
      },
      {
        "name": "Python magic / dunder",
        "scope": [
          "support.function.magic.python",
          "support.variable.magic.python",
          "variable.language.special.python"
        ],
        "settings": {
          "foreground": "#ffc24b"
        }
      },
      {
        "name": "Python builtin type",
        "scope": [
          "support.type.python",
          "support.type.exception.python"
        ],
        "settings": {
          "foreground": "#56d4dd"
        }
      },
      {
        "name": "Python builtin constant",
        "scope": [
          "constant.language.python"
        ],
        "settings": {
          "foreground": "#ff5d73"
        }
      },
      {
        "name": "Python CAPS constant",
        "scope": [
          "constant.other.caps.python",
          "constant.other.caps"
        ],
        "settings": {
          "foreground": "#ff5d73"
        }
      },
      {
        "name": "Python decorator",
        "scope": [
          "entity.name.function.decorator.python",
          "meta.function.decorator.python",
          "punctuation.definition.decorator.python",
          "support.type.python.decorator"
        ],
        "settings": {
          "foreground": "#b9a4f2"
        }
      },
      {
        "name": "Python function name & call",
        "scope": [
          "entity.name.function.python",
          "meta.function-call.generic.python",
          "meta.function-call.python entity.name.function"
        ],
        "settings": {
          "foreground": "#ffc24b"
        }
      },
      {
        "name": "Python class name",
        "scope": [
          "entity.name.type.class.python",
          "entity.name.class.python",
          "support.class.python"
        ],
        "settings": {
          "foreground": "#56d4dd"
        }
      },
      {
        "name": "Python f-string field",
        "scope": [
          "constant.character.format.placeholder.other.python",
          "meta.fstring.python constant.character.format.placeholder",
          "punctuation.definition.placeholder.python"
        ],
        "settings": {
          "foreground": "#ffc24b"
        }
      },
      {
        "name": "Python type hint",
        "scope": [
          "meta.function.parameters.python support.type.python",
          "meta.return-type.python support.type.python",
          "meta.typehint.python",
          "support.type.type-parameter.python"
        ],
        "settings": {
          "foreground": "#56d4dd"
        }
      },
      {
        "name": "Python logical / flow keyword",
        "scope": [
          "keyword.operator.logical.python",
          "keyword.control.flow.python",
          "keyword.control.import.python",
          "keyword.operator.python"
        ],
        "settings": {
          "foreground": "#ff7403"
        }
      }
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
      "comment": {
        "foreground": "#6f7fb0",
        "fontStyle": "italic"
      },
      "keyword": "#ff7403",
      "keywordLibrary": "#ff7403",
      "string": "#3edd9b",
      "number": "#ff5d73",
      "regexp": "#b9a4f2",
      "operator": "#a7b4d8",
      "function": "#ffc24b",
      "method": "#ffc24b",
      "macro": "#b9a4f2",
      "function.defaultLibrary": "#ffc24b",
      "method.defaultLibrary": "#ffc24b",
      "magicFunction": "#ffc24b",
      "class": "#56d4dd",
      "struct": "#56d4dd",
      "interface": "#56d4dd",
      "enum": "#56d4dd",
      "type": "#56d4dd",
      "namespace": "#56d4dd",
      "class.defaultLibrary": "#56d4dd",
      "type.defaultLibrary": "#56d4dd",
      "typeParameter": {
        "foreground": "#56d4dd",
        "fontStyle": "italic"
      },
      "variable": "#c9d1d9",
      "variable.readonly": "#ff5d73",
      "variable.readonly.defaultLibrary": "#ff5d73",
      "variable.defaultLibrary": "#93dafe",
      "builtinConstant": "#ff5d73",
      "parameter": "#93dafe",
      "property": "#93dafe",
      "property.readonly": "#ff5d73",
      "enumMember": "#ff5d73",
      "event": "#93dafe",
      "decorator": "#b9a4f2",
      "selfParameter": "#ff5d73",
      "clsParameter": "#ff5d73",
      "module": "#56d4dd",
      "variable.globalScope": "#93dafe",
      "*.static": {
        "fontStyle": "italic"
      },
      "*.abstract": {
        "fontStyle": "italic"
      },
      "*.deprecated": {
        "fontStyle": "strikethrough"
      }
    }
  }