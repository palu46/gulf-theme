{
  "name": "gulf-theme",
  "displayName": "Gulf Theme",
  "description": "A VS Code dark theme inspired by the iconic Porsche x Gulf racing livery, blending bold Gulf blue with vivid orange accents for a high-contrast coding experience.",
  "publisher": "alessandropaludetto",
  "version": "1.0.1",
  "icon": "theme-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/palu46/gulf-theme.git"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Gulf Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/gulf-dark-editor-color-theme.json"
      },
      {
        "label": "Gulf Dark (default editor)",
        "uiTheme": "vs-dark",
        "path": "./themes/gulf-dark-color-theme.json"
      }
    ]
  }
}
